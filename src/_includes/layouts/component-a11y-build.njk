<article data-template="a11yBuild">
    {%- block Introduction  %}
    <section id="overview">
        <h1>{{ title_h1 }}</h1>
        Are you in the right place?
        If you are constrained to a third-party component library, see the
        <a href="./accessibility-tests.html">Accordion Accessibility Checklist</a> and ensure that it passes.
        Otherwise, follow the guidance here to choose the best option for your project.
    </section>
    {% endblock -%}

    {%- block RecommendedSolution %}
    <section class="recommended-solution">
        <div class="card">
            <nys-badge label="Recommended" intent="success" prefixIcon></nys-badge>
            <h2>Use the NYSDS {{ parent }} Web Component</h2>
            <p>
                The NYSDS Accordion is a web component you can drop into your project and use right away.
                For most teams, this is the simplest way to implement an accessible accordion.
                This means teams don’t need to manually implement accessibility or test for it.
            </p>
            <h3>What's already handled for you</h3>
            <ul class="built-in color-theme--faint">
                <li>
                    <div class="built-in__start">
                        <nys-icon color="var(--nys-color-theme)" name="check_circle" size="24"></nys-icon>
                    </div>
                    <div class="built-in__end">
                        <strong>Keyboard Navigation</strong>
                        <p class="nys-font-body-sm"><kbd>Tab</kbd>, <kbd>Enter</kbd>, <kbd>Space</kbd> all work.</p>
                    </div>
                </li>
                <li>
                    <div class="built-in__start">
                        <nys-icon color="var(--nys-color-theme)" name="check_circle" size="24"></nys-icon>
                    </div>
                    <div class="built-in__end">
                        <strong>Focus management</strong>
                        <p class="nys-font-body-sm">Focus stays where users expecting</p>
                    </div>
                </li>
                <li>
                    <div class="built-in__start">
                        <nys-icon color="var(--nys-color-theme)" name="check_circle" size="24"></nys-icon>
                    </div>
                    <div class="built-in__end">
                        <strong>Zoom magnification</strong>
                        <p class="nys-font-body-sm">Works correctly at 200% browser zoom</p>
                    </div>
                </li>
                <li>
                    <div class="built-in__start">
                        <nys-icon color="var(--nys-color-theme)" name="check_circle" size="24"></nys-icon>
                    </div>
                    <div class="built-in__end">
                        <strong>Screen reader support</strong>
                        <p class="nys-font-body-sm">Tested with NVDA, JAWS, and VoiceOver</p>
                    </div>
                </li>
                <li>
                    <div class="built-in__start">
                        <nys-icon color="var(--nys-color-theme)" name="check_circle" size="24"></nys-icon>
                    </div>
                    <div class="built-in__end">
                        <strong>Voice control</strong>
                        <p class="nys-font-body-sm">Supports Windows and macOS</p>
                    </div>
                </li>
                <li>
                    <div class="built-in__start">
                        <nys-icon color="var(--nys-color-theme)" name="check_circle" size="24"></nys-icon>
                    </div>
                    <div class="built-in__end">
                        <strong>WCAG 2.2 AA conformant</strong>
                        <p class="nys-font-body-sm">Meets New York State standards</p>
                    </div>
                </li>
            </ul>
            <nys-button href="./" label="View NYSDS {{ parent }} Component" fullWidth></nys-button>
        </div>
    </section>
    {% endblock -%}

    <nys-divider></nys-divider>

    <section class="alternative-solutions">
        <h2>Alternatives</h2>
        <p>
            <mark>For projects not ready to adopt the Design System</mark>
            Whether you seek to remediate an existing component or build one from scratch,
            these reference implementations will ensure an accessible outcome.
            For more details, <a href="#about-this-pattern">read about this pattern</a>.
        </p>
        {%- block Alternatives %}
        {% endblock -%}
    </section>

    <nys-divider></nys-divider>

    <section class="about-this-pattern">
        <h2>About this pattern</h2>
        {%- block AboutThisPattern %}
        {% endblock -%}
    </section>

    {% include "partials/a11y-contact-points.njk" %}
</article>
