            <nys-badge intent="{{ i }}" label="{{ interaction.status }}" prefixIcon></nys-badge>
          </div>
      </div>
      {% endfor %}
      {% endblock -%}
    </section>

    <section>
      <h3>Desktop screen reader</h3>
      {%- block screenreader %}
      <p>
          <!-- TODO: add HREFs -->
          Test with at least two out of the three most common screen readers.
          <a href="https://www.nvaccess.org/download/" target="_blank">NVDA</a> runs under Windows and is a free download.
          <a href="https://support.freedomscientific.com/Downloads/JAWS" target="_blank">JAWS</a> runs under Windows and is a commercial product.
          <a href="https://support.apple.com/guide/voiceover/welcome/mac" target="_blank">VoiceOver</a> is built into macOS.
          While using a screen reader do not use a mouse whatsoever.
      </p>

      {% for interaction in screenReader.interactions %}
      <div class="card--a11ytest">
          <div>
              <nys-checkbox label="" aria-describedby=""></nys-checkbox>
          </div>
          <div>
            <h4>{{ interaction.scenario | safe }}</h4>
            <ul>
                {% for requirement in interaction.requirements %}
                <li>{{ requirement }}</li>
                {% endfor %}
            </ul>
            {% set i = "success" if interaction.status | upper == "PASS" else ("error" if interaction.status | upper == "FAIL" else ("warning" if interaction.status | upper == "NOT DONE" else "")) %}
            <nys-badge intent="{{ i }}" label="{{ interaction.status }}" prefixIcon></nys-badge>
          </div>
      </div>
      {% endfor %}
      {% endblock -%}
    </section>

    <section>
      <h3>Mobile screen reader</h3>
      {%- block screenreadermobile %}
      <p>
        Test with at least one, ideally both, of the primary mobile screen readers.
        <a href="https://support.apple.com/guide/iphone/turn-on-and-practice-voiceover-iph3e2e415f/ios" target="_blank">VoiceOver</a>
        is part of iOS and
        <a href="https://support.google.com/accessibility/android/answer/6283677?hl=en" target="_blank">TalkBack</a>
        is included with most Android devices.
      </p>

      {% for interaction in screenReaderMobile.interactions %}
      <div class="card--a11ytest">
          <div>
              <nys-checkbox label="" aria-describedby=""></nys-checkbox>
          </div>
          <div>
