<section>
    <h2>Use this checklist at the design stage</h2>
    {%- block wcag %}
    <p>
        This checklist breaks down the specific design and interaction requirements behind the tests above,
        organized by disability type so you can see exactly who each requirement serves and what it means in practice.
        Each item links to the related
        <a href="https://www.w3.org/WAI/WCAG22/quickref/" target="_blank">WCAG 2.2 resources</a>.
    </p>
    {% for wcag in disabilities %}
    <h3>{{ wcag.type }}</h3>
    {% for criterion in wcag.criteria %}
    <div class="card--a11ytest">
        <div class="card--a11ytest__start">
            <input type="checkbox" aria-label="Mark when {{ wcag.type }} requirement {{ loop.index }} is ensured" aria-describedby="{{ wcag.type }}-desc-{{ loop.index }}">
        </div>
        <div class="card--a11ytest__end" id="{{ wcag.type }}-desc-{{ loop.index }}">
            <h4>{{ criterion.description }}</h4>
            <a href="{{ criterion.uri }}" target="_blank">
                {{ criterion.sc }}
            </a>
        </div>
    </div>
    {% endfor %}
    {% endfor %}
    {% endblock -%}
</section>
