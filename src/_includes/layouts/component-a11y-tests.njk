<section id="overview">
    <h1>{{ title }}</h1>
    {%- block longdescription %}
    Any {{ pattern }} used in a New York State website should pass these tests and checklists.
    Also follow this acceptance criteria when building and testing a
    <a href="./accessibility-build.html">custom {{ pattern }}</a>
    and when evaluating third-party open source or licensed component libraries.
    {% endblock -%}
</section>

<section>
    {%- block teststatus %}
    <nys-table bordered>
        <table>
            <caption>
                NYSDS {{ pattern | capitalize }} accessibility status
            </caption>
            <tr>
                <th>Total tests</th>
                <th>Passes</th>
                <th>Fails</th>
                <th>To do</th>
            </tr>
            <tr>
                <td>{{ tests.total }}</td>
                <td>{{ tests.pass }}</td>
                <td>{{ tests.fail }}</td>
                <td>{{ tests.toDo }}</td>
            </tr>
        </table>
    </nys-table>
    {% endblock -%}
</section>

<section>
    <h2>Accessibility tests</h2>
    {%- block anyonecandoit %}
    <div class="card--bisect">
        <div class="card--bisect__start color-theme--faint">
            <h3>Anyone can run these accessibility tests, no special tools needed.</h3>
            <p>
                Each passing test removes a real barrier for New Yorkers who navigate by keyboard,
                screen reader, or voice control.
            </p>
        </div>
        <div class="card--bisect__end">
            <div>
                <i class="color-theme--faint"><nys-icon color="var(--nys-color-theme)" name="search" size="18"></nys-icon></i>
                <h4>Find what you need</h4>
                <p>
                    All of these tests can be run from your browser.
                    Each section tells you what to use and where to get it.
                </p>
            </div>
            <div>
                <i class="color-theme--faint"><nys-icon color="var(--nys-color-theme)" name="edit_square" size="16"></nys-icon></i>
                <h4>Follow the checklists</h4>
                <p>
                    Each checkbox tells you exactly what to do and what a passing result looks or sounds like.
                </p>
            </div>
            <div>
                <i class="color-theme--faint"><nys-icon color="var(--nys-color-theme)" name="check" size="20"></nys-icon></i>
                <h4>Track and share results</h4>
                <p>
                    Run each test, record what passes and what needs work, and print your results to share with your team.
                </p>
            </div>
        </div>
    {% endblock -%}
</section>

<section>
    <h3>Keyboard navigation</h3>
    {%- block keyboard %}
    <p>
        Limit interaction with the component to only the <kbd>Tab</kbd>, <kbd>Enter</kbd>, and <kbd>Space</kbd> keys.
        While testing keyboard navigation do not use a mouse whatsoever.
    </p>

    {% for interaction in keyboard.interactions %}
    <div class="card--a11ytest">
        <div class="card--a11ytest__start">
            <input type="checkbox" aria-label="Mark when keyboard test {{ loop.index }} passes" aria-describedby="keyboard-desc-{{ loop.index }}">
        </div>
        <div class="card--a11ytest__end" id="keyboard-desc-{{ loop.index }}">
            <h4>{{ interaction.scenario | safe }}</h4>
            <ul>
                {% for requirement in interaction.requirements %}
                <li>{{ requirement | safe }}</li>
                {% endfor %}
            </ul>
            <span class="sr-only">keyboard test {{loop.index}}</span>
            <nys-badge label="{{ interaction.status[0] }}" intent="{{ interaction.status[1] }}" prefixIcon></nys-badge>
        </div>
    </div>
    {% endfor %}
    {% endblock -%}
</section>

<section>
    <!-- TODO: write acceptance criteria and description for MOUSE !! -->
