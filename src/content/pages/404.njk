      {# <p><a href="mailto:designsystem@its.ny.gov">designsystem@its.ny.gov</a></p> #}
      <script>
        {# search the site when you press enter key in the search field #}
        document.getElementById("q").addEventListener("keypress", function(event) {
          if (event.key === "Enter") {
            event.preventDefault();
            search();
          }
        });

        {# Submit the form when you keypress or click the submit button #}
        document.getElementById("searchButton").addEventListener("nys-click", () => { 
          search();
        });

        {# grab the value of the "q" search text field and send the query to the search page #}
        function search() {
          var searchInput = document.getElementById('q');
          var url = "/search/?q=" + searchInput.value;
          window.open(url, "_self");
        }
      </script>


