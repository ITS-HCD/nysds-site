{% block styles %}
<link rel="stylesheet" href="{{ '/assets/fonts/atkinson-hyperlegible/atkinson-hyperlegible.css' | url }}">
{% endblock %}

{% block scripts %}
<script>
  (function () {
    const pagination = document.getElementById('cards-pagination');
    const pages = document.querySelectorAll('.card-page');
    const announcement = document.getElementById('card-page-announcement');

    pagination.addEventListener('nys-change', function (e) {
      const newPage = e.detail.page;
      pages.forEach(function (page, i) {
        page.hidden = (i + 1) !== newPage;
      });
      announcement.textContent = '';
      requestAnimationFrame(function () {
        announcement.textContent = 'Showing set ' + newPage + ' of 3';
      });
    });
  })();
</script>
