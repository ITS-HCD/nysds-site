{% extends "layouts/base.njk" %}

{% block content %}
<!-- Home Hero -->
<div class="hero">
  <div class="hero__inner">
    <div class="hero__content">
      <svg width="150" height="13" viewBox="0 0 209 13" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-left:6px;">
        <rect x="104.33" width="52.1654" height="12.9576" fill="#FACE00"/>
        <rect x="156.498" width="52.1654" height="12.9576" fill="#0E324F"/>
        <rect x="52.166" width="52.1654" height="12.9576" fill="#004DD1"/>
        <rect width="52.1654" height="12.9576" fill="#A2350A"/>
      </svg>
      <h1>Be<span class="letter--tight"> </span>an<span class="letter--tight"> </span><span class="heavy"><span class="letter-not-so--tight">a1</span>1y.</span></h1>
      <p style="margin-left: 5px;">Accessible design is better for everyone.</p>
    </div>
    <div class="hero__media">
      <img src="{{ '/assets/img/a11y-banner.png' | url }}" style="width: 80%;" alt="">
    </div>
  </div>
</div>

<style>
.letter--tight {
  letter-spacing: -6px;
}

.letter-not-so--tight {
  letter-spacing: -4px;
}

.hero *,
.a11y-card * {
  color: var(--nys-color-theme-strong);
}

@media (width > 1024px) {
  .hero h1 {
    font-size: 96px;
    line-height: 1;
    margin-top: var(--nys-space-200);
    margin-bottom: var(--nys-space-100);
  }
}

@media (width <= 1024px) {
  .hero__inner {
    flex-direction: column;
  }
}
.hero p {
  font-size: var(--nys-font-size-5xl);
  line-height: 1.2;
}

.hero h1,
.hero p,
.a11y-card h3,
.a11y-card p {
  font-family: 'Atkinson Hyperlegible Next', sans-serif;
  font-weight: 200;
}

.a11y-card h3 {
  margin-top: var(--nys-space-200);
}

.hero p,
.a11y-card p {
  font-weight: normal;
}

.heavy {
  font-weight: 500;
}

.a11y-card p {
  font-size: 1.125rem;
}

.a11y-card .fake-h3 {
  font-size: var(--nys-font-size-h3);
  margin-top: var(--nys-space-200);
}

@media (width > 1024px) {
  .card-page {
    height: 420px;
  }
}

.a11y-sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

  .poster-deck-wrapper {
    padding: 3rem 0 5rem;
    overflow-x: auto;
  }

.poster-deck img {
  width: 100px;
  }

@media (width > 768px) {

  .poster-deck {
    position: relative;
    width: 700px;
    height: 420px;
    margin: 0 auto;
  }

  .poster-deck img {
    position: absolute;
    width: 170px;
    height: auto;
    cursor: pointer;
    box-shadow: 2px 4px 14px rgba(0, 0, 0, 0.25);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    transform: rotate(var(--r, 0deg));
  }


  .poster-deck img:nth-child(1) { z-index: 1; left: 0px;   top: 130px; --r: -16deg; }
  .poster-deck img:nth-child(2) { z-index: 2; left: 65px;  top: 80px;  --r: -11deg; }
  .poster-deck img:nth-child(3) { z-index: 3; left: 130px; top: 45px;  --r: -6deg;  }
  .poster-deck img:nth-child(4) { z-index: 4; left: 195px; top: 20px;  --r: -2deg;  }
  .poster-deck img:nth-child(5) { z-index: 5; left: 265px; top: 10px;  --r: 0deg;   }
  .poster-deck img:nth-child(6) { z-index: 6; left: 335px; top: 20px;  --r: 2deg;   }
  .poster-deck img:nth-child(7) { z-index: 7; left: 400px; top: 45px;  --r: 6deg;   }
  .poster-deck img:nth-child(8) { z-index: 8; left: 465px; top: 80px;  --r: 11deg;  }
  .poster-deck img:nth-child(9) { z-index: 9; left: 530px; top: 130px; --r: 16deg;  }

  .poster-deck img:hover,
  .poster-deck img:focus {
    z-index: 100;
    transform: rotate(var(--r, 0deg)) translateY(-24px) scale(1.07);
    box-shadow: 6px 16px 32px rgba(0, 0, 0, 0.4);
    outline: 3px solid var(--nys-color-theme-strong, #004DD1);
    outline-offset: 4px;
  }
}


</style>

