{% block styles %}
<link rel="stylesheet" href="{{ '/assets/fonts/atkinson-hyperlegible/atkinson-hyperlegible.css' | url }}">
<style>

main[role="main"] {
  padding-bottom: 0;
}

.letter--tight {
  letter-spacing: -6px;
}

.letter-not-so--tight {
  letter-spacing: -4px;
}

.a11y-color-mark {
  margin-left: -10px;
}

@media (width > 768px) {
  .a11y-color-mark {
    margin-left: 6px;
  }
}

.hero *,
.a11y-card * {
  color: var(--nys-color-theme-strong);
}

.hero h1 {
  margin-top: var(--nys-space-50);
}

@media (width > 1024px) {
  .hero h1 {
    font-size: 96px;
    line-height: 1;
    margin-top: var(--nys-space-200);
    margin-bottom: var(--nys-space-100);
  }
}

.hero p {
  font-size: var(--nys-font-size-5xl);
  line-height: 1.2;
}

.hero h1,
.hero p,
.a11y-card h3,
.a11y-card p {
  font-family: 'Atkinson Hyperlegible Next', sans-serif;
  font-weight: 200;
}

.a11y-card h3 {
  margin-top: var(--nys-space-200);
}

.hero p,
.a11y-card p {
  font-weight: normal;
}

.heavy {
  font-weight: 500;
}

.a11y-card p {
  font-size: 1.125rem;
}

.a11y-card .fake-h3 {
  font-size: var(--nys-font-size-h3);
  margin-top: var(--nys-space-200);
}



@media (width > 1024px) {
  .card-page {
    height: 420px;
  }
}

.a11y-sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

  .poster-deck-wrapper {
    padding: 3rem 0 5rem;
  }

.poster-deck img {
  width: 100px;
  }

.poster-deck {
  display: none;
  margin-top: var(--nys-space-800);
}

@media (width > 768px) {

  .poster-deck {
    display: block;
    position: relative;
    width: 700px;
    height: 420px;
    margin: var(--nys-space-800) auto 0 auto;
  }

  .poster-deck img {
    position: absolute;
    width: 170px;
    height: auto;
    box-shadow: 2px 4px 14px rgba(0, 0, 0, 0.25);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    transform: rotate(var(--r, 0deg));
  }


  .poster-deck img:nth-child(1) { z-index: 1; left: 0px;   top: 130px; --r: -16deg; }
  .poster-deck img:nth-child(2) { z-index: 2; left: 65px;  top: 80px;  --r: -11deg; }
  .poster-deck img:nth-child(3) { z-index: 3; left: 130px; top: 45px;  --r: -6deg;  }
  .poster-deck img:nth-child(4) { z-index: 4; left: 195px; top: 20px;  --r: -2deg;  }
  .poster-deck img:nth-child(5) { z-index: 5; left: 265px; top: 10px;  --r: 0deg;   }
  .poster-deck img:nth-child(6) { z-index: 6; left: 335px; top: 20px;  --r: 2deg;   }
  .poster-deck img:nth-child(7) { z-index: 7; left: 400px; top: 45px;  --r: 6deg;   }
  .poster-deck img:nth-child(8) { z-index: 8; left: 465px; top: 80px;  --r: 11deg;  }
  .poster-deck img:nth-child(9) { z-index: 9; left: 530px; top: 130px; --r: 16deg;  }

  .poster-deck img:hover,
  .poster-deck img:focus {
    z-index: 100;
    transform: rotate(var(--r, 0deg)) translateY(-24px) scale(1.07);
    box-shadow: 6px 16px 32px rgba(0, 0, 0, 0.4);
    /* outline: 3px solid var(--nys-color-theme-strong, #004DD1); */
    outline-offset: 4px;
  }
}

.full-size-posters a {
  display: inline-block;
}

.full-size-posters img {
  max-width: 100%;
  margin-bottom: var(--nys-space-200);
}

.full-size-posters {
  text-align: center;
}

.responsive-grid-break {
  padding: 0!important;
}

@media (width > 1024px) {
  .responsive-grid-break {
    flex-basis: 100%;
    height: 0;
  }
}

.non-breaking-space {
  white-space: nowrap;
}

</style>
{% endblock %}

{% block scripts %}
<script>
  let currentIndex = 0; // track which div is showing

  function showRandomDiv() {
    const divs = document.querySelectorAll('.card-page');
    
    // Pick a random index that's different from the current one
    let newIndex;
    do {
      newIndex = Math.floor(Math.random() * divs.length);
    } while (newIndex === currentIndex);

    divs[currentIndex].style.display = 'none';
    divs[newIndex].style.display = 'block';
    currentIndex = newIndex;

const isMobile = window.matchMedia('(max-width: 768px)').matches;

    if (isMobile) {
      document.getElementById('card-page-container').scrollIntoView({ behavior: 'smooth' });
    }
  }
</script>
{% endblock %}
