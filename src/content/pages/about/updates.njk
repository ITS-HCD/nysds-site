---
permalink: /about/updates/
title: "Updates"
navTitle: "Updates"
navOrder: 4
section: About
description: "Stay current with the NYS Design System — releases, new components, and articles."
---

{% set latestRelease = null %}
{% set latestArticle = null %}
{% for post in collections.updates %}
  {% if not latestRelease and post.data.tags and "release" in post.data.tags %}
    {% set latestRelease = post %}
  {% endif %}
  {% if not latestArticle and post.data.tags and "article" in post.data.tags %}
    {% set latestArticle = post %}
  {% endif %}
{% endfor %}

{% block content %}

<h1>Updates</h1>

<p>Stay current with the NYS Design System. Find the latest releases, component updates, and articles about building accessible digital services for New York State.</p>

<nys-alert type="info" heading="Subscribe to Updates">Email notifications for new releases and articles are coming soon.</nys-alert>

{% if latestRelease %}
<section id="latest-release">

<h2>Latest Release</h2>

<div class="card card--horizontal">
    <div class="card__content">
        <h3 class="card__title">
            <a href="{{ latestRelease.url }}">{{ latestRelease.data.title }}</a>
        </h3>
        <div class="card__desc">
            {{ latestRelease.data.description }}
        </div>
        <div class="card__meta" style="margin-top: 1rem;">
            <time datetime="{{ latestRelease.data.date | dateISO }}">{{ latestRelease.data.date | dateFull }}</time>
        </div>
    </div>
</div>

</section>
{% endif %}

{% if latestArticle %}
<section id="latest-article">

<h2>Latest Article</h2>

<div class="card card--horizontal">
    <div class="card__content">
        <h3 class="card__title">
            <a href="{{ latestArticle.url }}">{{ latestArticle.data.title }}</a>
        </h3>
        <div class="card__desc">
            {{ latestArticle.data.description }}
        </div>
        <div class="card__meta" style="margin-top: 1rem;">
            <time datetime="{{ latestArticle.data.date | dateISO }}">{{ latestArticle.data.date | dateFull }}</time>
        </div>
    </div>
</div>

</section>
{% endif %}

<p><a href="/about/updates/all/">View all updates →</a></p>

{% endblock %}
